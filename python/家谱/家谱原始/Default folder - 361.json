", "孙国平号称“铁算盘”，次孙国璋的彩绘人物画当地知名。佐唐先生在县西一带", "声名远播，乡邻们遇到大事难事，多找其出注意、想办法，称：“秀才不出门，", "遍知天下闻”，赞佐唐是杜氏的“文状元”。", "杜国玺整理", "2008年12月"], "rec_scores": [0.9911688566207886, 0.9799984693527222, 0.985506534576416, 0.9970113039016724, 0.9922226071357727, 0.9962558746337891, 0.9970201253890991, 0.999801516532898, 0.9981712698936462, 0.807265043258667, 0.9965112209320068, 0.9926477670669556, 0.9846805334091187, 0.9943318367004395, 0.9919912219047546, 0.9962140321731567, 0.996337354183197, 0.9968695640563965, 0.9878416657447815, 0.992902398109436, 0.990088939666748, 0.9960588812828064, 0.9913970828056335, 0.9937600493431091, 0.9980345368385315, 0.9957882165908813, 0.9970206022262573, 0.9958065152168274, 0.9832600355148315, 0.9871636629104614, 0.9927684664726257, 0.9869338870048523, 0.9948777556419373, 0.9934439659118652, 0.9902952909469604, 0.9879323244094849, 0.9959633946418762, 0.9998160600662231], "rec_polys": [[[317, 239], [1794, 241], [1794, 291], [317, 289]], [[319, 306], [1791, 307], [1791, 358], [319, 357]], [[319, 373], [1793, 371], [1793, 421], [319, 423]], [[319, 439], [1008, 439], [1008, 489], [319, 489]], [[404, 505], [1793, 507], [1793, 555], [404, 553]], [[321, 573], [1261, 574], [1261, 621], [321, 620]], [[997, 639], [1468, 642], [1467, 686], [996, 683]], [[1548, 639], [1792, 639], [1792, 688], [1548, 688]], [[407, 706], [670, 704], [670, 749], [407, 751]], [[121, 722], [225, 722], [225, 934], [121, 934]], [[408, 770], [1795, 776], [1795, 823], [408, 817]], [[320, 835], [1758, 839], [1758, 892], [319, 888]], [[406, 902], [1796, 909], [1796, 959], [406, 952]], [[324, 968], [1795, 973], [1795, 1023], [323, 1018]], [[132, 1031], [218, 1031], [218, 1441], [132, 1441]], [[322, 1033], [1794, 1037], [1794, 1087], [321, 1083]], [[323, 1099], [1793, 1104], [1793, 1151], [322, 1146]], [[324, 1164], [1795, 1168], [1795, 1215], [323, 1211]], [[325, 1230], [1792, 1234], [1792, 1281], [324, 1277]], [[327, 1295], [1793, 1300], [1793, 1344], [326, 1339]], [[325, 1361], [1789, 1364],