box": false, "rec_texts": ["十一世杜林元：廷行次子，武生。", "十一世杜林茂：廷行三子，武生。", "十一世杜林川：廷行四子，佾生。", "十一世杜星五：廷用次子，生员。", "十一世杜林皋：从九。", "十二世杜成林：从九。", "十二世杜嘉林：乙未科副榜，武陟县训导。", "渑池", "十二世杜泮林：从九。", "十三世杜朝栋：林皋孙，佾生。", "十三世杜朝楹：泮林子，配王氏，子一，公早殁，遗子希贤仅七岁，王氏守节自誓，姑", "李氏年老失明，王氏殷切扶持，能得其欢心，勤俭持家，严师训子，克振家声云。", "十三世杜朝梁：泮林子，从九。", "杜氏宗谱", "十三世杜希贤：朝楹子，公幼失怙，克振家声，侍母至孝，人无间言。", "十三世杜芳春：公生于一八六八年(同治八年)，卒于一九五八年，享寿九十，一生克", "勤克俭，维孝维慈。八十八岁时耳不聋眼不花，身直体壮，白发长须。因劳跌伤，卧床", "二年而殁。卒之日，一弟、四子、十孙、十曾孙、一元孙、四儿媳、九孙女、八孙媳、二", "曾孙媳、五曾孙女、一元孙女，五世同堂，人称贤翁焉。", "十四世杜象贤：朝梁子，佾生。", "十四世杜鼎新：芳春子，开封师院毕业。", "十四世杜裔云：希贤子，公自幼勤学，通文精医，擅长针灸，技艺精湛，医德淳厚，闻", "名当时。渑池人民医院中医师。", "十四世杜玉琢：公乃驰名兽医，技术精湛，医德高尚，年近九旬，依然为民服务。", "十五世杜俊杰妻张氏：三十二岁守节，孝敬公姑，抚养孤子松范，含辛茹苦，履境难", "堪，积七旬时四世同堂，名闻乡里焉。", "十五世杜俊英：洛阳铭德中学毕业，执教两载，升校长。以目疾弃教从医，拜名医周", "学儒为师，1958年，父母辞世，乃悲伤过度，双目失明。公系当时名医，驰名邻县，德", "高望重，仗义疏财，求医者、请教者、议事者络绎不绝。年届七旬，乃全力组织纂修", "三1", "宗谱，，并口述序言。见本谱杜俊英墓碑文。", "十五世杜俊良：公自幼好学，长于史、地，编有《历史门径》，又整理有《医学汇编》。", "十五世杜忠琪：参加中国人民志愿军，抗美援朝，在朝鲜牺牲，安葬在朝鲜第二烈士", "陵园。", "十五世杜福礼：经商致富，不忘其本。详修祠读谱功德碑。", "十六世杜青松：毕业于西安地质学院，任新疆自治区地质探测队高级工程师。"], "rec_scores": [0.9626453518867493, 0.9718701839447021, 0.9783505201339722, 0.9739846587181091, 0.9802859425544739, 0.9784222841262817, 0.9782471060752869, 0.8846515417098999, 0.9783989787101746, 0.9663456678390503, 0.9737676382064819, 0.9889400005340576, 0.9811218976974487, 0.9916080832481384, 0.9767801761627197, 0.9516589641571045, 0.9881106019020081, 0.9711982607841492, 0.9882324934005737, 0.9650002121925354, 0.9825046062469482, 0.9739599823951721, 0.9889425039291382, 0.9806506633758545, 0.9799131155014038, 0.9869012236595154, 0.9810262322425842, 0.974322497844696, 0.9705386757850647, 0.6398851871490479, 0.9824249148368835, 0.9684350490570068, 0.9713694453239441, 0.9987597465515137, 0.9771715998649597, 0.9875174164772034], "rec_polys": [[[183, 235], [769, 239], [769, 290], [182, 286]], [[185, 310], [768, 310], [768, 357], [185, 357]], [[186, 381], [766, 381], [766, 425], [186, 425]], [[187, 452], [764, 452], [764, 497], [187, 497]], [[187, 524], [572, 524], [572, 568], [187,