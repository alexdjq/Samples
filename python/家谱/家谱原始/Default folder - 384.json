葬正南莹。生子四人：伯祖如桧暨玉祖如松附葬焉；高祖葬此茔祖穴，二伯祖如林、四叔祖如梅附葬焉。先伯叔惇、英等以孙不可祢祖，乃立石于高祖之墓前，以代曾祖之神主。玉等恐后裔不知其详，诬认高祖之墓为曾祖之墓焉。因叙明其由：高祖讳光衍，浙江金华府东阳县城西人，配王氏。生曾祖二人。曾祖生玉祖兄弟四人，并附茔图于右，以便觇览。\n\n\n\n曾孙怀玉拜撰，元孙基书丹\n\n公高明\n\n皇清待赠杜讳之神主\n\n母裴氏\n\n男孙曾孙元孙云孙仍孙（名皆从略）仝立\n\n\n\n<div style=\"text-align: center;\"><img src=\"imgs/img_in_image_box_1201_1487_1581_2391.jpg\" alt=\"Image\" width=\"19%\" /></div>\n\n\n三八四", "isStart": false, "isEnd": true, "images": {"imgs/img_in_image_box_1201_1487_1581_2391.jpg": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//c697226c-314f-4635-bedc-6f45d31782c0/markdown_0/imgs/img_in_image_box_1201_1487_1581_2391.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A32%3A14Z%2F-1%2F%2F500464e175afe581db21e9a7f6886052226f3f42aafa3a3da26fb108b889a26b"}}, "outputImages": {"layout_det_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//c697226c-314f-4635-bedc-6f45d31782c0/layout_det_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A32%3A15Z%2F-1%2F%2F5ddf42bb3b841fa44a7b915d8254226298a16658e8e4e0058e954c67ba07170c", "region_det_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//c697226c-314f-4635-bedc-6f45d31782c0/region_det_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A32%3A15Z%2F-1%2F%2Fb530beb835fcf2dc2a26a0478ee41a36f5c868abb447a85df549a2456ff1ccf3", "overall_ocr_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//c697226c-314f-4635-bedc-6f45d31782c0/overall_ocr_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A32%3A16Z%2F-1%2F%2F9184be4be581f0e3224e62063a546fb2687f4759ad64c2bdfecadcc755dff94e", "layout_order_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//c697226c-314f-4635-bedc-6f45d31782c0/layout_order_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaR