祭祖典礼。首先，请允许我代表渑池杜氏宗族修祠续谱\n\n", "isStart": false, "isEnd": true, "images": {}}, "outputImages": {"layout_det_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//a1b7c07d-84c9-4be7-8033-46003d2f5166/layout_det_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A31%3A37Z%2F-1%2F%2Faeee2a97775188503bc006352ae2d00bf54a163e4df224f96f471d049e03ff65", "region_det_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//a1b7c07d-84c9-4be7-8033-46003d2f5166/region_det_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A31%3A37Z%2F-1%2F%2Ff5f7030a6a2de8be8a38e3da5fdf47e651b13a9e399d657160396cbf1547fdcb", "overall_ocr_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//a1b7c07d-84c9-4be7-8033-46003d2f5166/overall_ocr_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A31%3A37Z%2F-1%2F%2Fa3a7f342f347a125a4d53269656c54e27d2cc55e883cc2fa15fcf7e186798982", "layout_order_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//a1b7c07d-84c9-4be7-8033-46003d2f5166/layout_order_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A31%3A38Z%2F-1%2F%2Fdf73b36f14c2af31b91082f350febc62730a7a3ac9421126bb88c1b4357e1770"}, "inputImage": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//a1b7c07d-84c9-4be7-8033-46003d2f5166/input_img_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A31%3A37Z%2F-1%2F%2Fb0c5bb1ba11984aaff1d803652255268e6bd74573d0e06541d1894a6d77e55ee"}], "dataInfo": {"width": 1869, "height": 2588, "type": "image"}, "ocrResults": [{"prunedResult": {"model_settings": {"use_doc_preprocessor": false, "use_textline_orientation": true}, "dt_polys": [[[375, 238], [710, 242], [710, 289], [374, 285]], [[376, 305], [1665, 304], [1665, 347], [376, 348]], [[376, 36