{"layoutParsingResults": [{"prunedResult": {"page_count": null, "width": 1954, "height": 2715, "model_settings": {"use_doc_preprocessor": false, "use_seal_recognition": true, "use_table_recognition": true, "use_formula_recognition": true, "use_chart_recognition": false, "use_region_detection": true, "format_block_content": false, "markdown_ignore_labels": ["number", "footnote", "header", "header_image", "footer", "footer_image", "aside_text"]}, "parsing_res_list": [{"block_label": "paragraph_title", "block_content": "渑池杜氏宗谱", "block_bbox": [173, 719, 250, 1414], "block_id": 0, "block_order": 1}, {"block_label": "paragraph_title", "block_content": "修祠续谱捐资榜（截至2010年5月）", "block_bbox": [822, 223, 1312, 384], "block_id": 1, "block_order": 2}, {"block_label": "text", "block_content": "窑湾苏民二万元\n\n上西村杜军一万五千元\n\n上西村明礼北坻坞韶光各一万元\n\n北坻坞智起五千八百八十八元\n\n窑湾平泉上西村杜震北坻坞福礼火洼景敏\n各五千元\n\n", "block_bbox": [331, 455, 1268, 850], "block_id": 2, "block_order": 3}, {"block_label": "text", "block_content": "窑湾百锁平安各三千元\n\n王都黎明温庄学曾上西村克宣各二千元\n东张村宗文一千一百三十元\n\n杜窑宝华一千零五十元\n\n", "block_bbox": [334, 928, 1173, 1181], "block_id": 3, "block_order": 4}, {"block_label": "text", "block_content": "上西村松范中楼光明克让玉群 常俊王都建成北坻坞建起连章来起窑湾荣身南坻坞宗民杜窑宝平温庄作秀各一千元\n", "block_bbox": [336, 1258, 1173, 1509], "block_id": 4, "block_order": 5}, {"block_label": "text", "block_content": "大水沟门火洼宗杰仁村伟华杜坑忠义各六百元\n\n徐坡门杜家闲明礼温庄温贤二宏丙战书伟素霞\n\n窑湾俊青苏伟克然书强国勤金锁明松克勤克宣灵爱智敏\n火洼龙文耀伟北坻坞聪明建杰明起根起\n\n南张村克智小有甲申瑞平东坡爱军南坻坞明军\n上西村伏翎旭辉旭峰勤松中明群娃亚伟法宗\n西窑书敏杜坑振东振勇兴洲华玺岭南专芳\n\n各五百元\n\n", "block_bbox": [334, 1586, 1801, 2111], "block_id": 5, "block_order": 6}, {"block_label": "text", "block_content": "上西村杜娟玉红灵振温庄三秃学民智伟孟村来法\n窑湾希庆长青银明武坡建伟杜坑云安\n各三百元\n\n", "block_bbox": [336, 2186, 1451, 2377], "block_id": 6, "block_order": 7}], "layout_det_res": {"boxes": [{"cls_id": 2, "label": "text", "score": 0.8375205397605896, "coordinate": [334.8893127441406, 928.986572265625, 1173.8790283203125, 1181.50390625]}, {"cls_id": 2, "label": "text", "score": 0.7763102054595947, "coordinate": [331.6839904785156, 455.248291015625, 1268.7149658203125, 850.3616943359375]}, {"cls_id": 2, "label": "text", "score": 0.7452843189239502, "coordinate": [336.18035888671875, 2186.70068359375, 1451.65771484375, 2377.75439453125]}, {"cls_id": 2, "label": "text", "score": 0.7381760478019714, "coordinate": [336.3931884765625, 1258.664306640625, 1173.8028564453125, 1509.528564453125]}, {"cls_id": 2, "label": "text", "score": 0.6386787295341492, "coordinate": [334.060546875, 1586.66943359375, 1801.832275390625, 2111.33203125]}, {"cls_id": 0, "label": "paragraph_title", "score": 0.5023999810218811, "coordinate": [822.3423461914062, 223.2979736328125, 1312.97119140625, 384.02337646484375]}, {"cls_id": 0, "label": "paragraph_title", "score": 0.38448435068130493, "coordinate": [173.76004028320312, 719.45458984375, 250.62881469726562, 1414.059814453125]}]}, "overall_ocr_res": {"model_settings": {"use_doc_preprocessor": false, "use_textline_orientation": true}, "dt_polys": [[[822, 227], [1314, 223], [1315, 303], [822, 307]], [[846, 318], [1294, 314], [1294, 380], [846, 383]], [[338, 458], [512, 458], [512, 511], [338, 511]], [[586, 459], [721, 459], [721, 513], [586, 513]], [[338, 526], [555, 524], [556, 577], [339, 579]], [[589, 530], [799, 530], [799, 579], [589, 579]], [[340, 594], [556, 594], [556, 646], [340, 646]], [[590, 597], [802, 597], [802, 646], [590, 646]], [[830, 596], [1002, 596], [1002, 645], [830, 645]], [[340, 664], [555, 664], [555, 713], [340, 713]], [[591, 667], [920, 665], [920, 710], [591, 712]], [[161, 709], [262, 709], [262, 917], [161, 917]], [[339, 729], [516, 729], [516, 782], [339, 782]], [[591, 732], [800, 734], [799, 780], [590, 777]], [[835, 734], [1041, 730], [1041, 776], [835, 780]], [[1077, 731], [1249, 731], [1249, 780], [1077, 780]], [[339, 797], [516, 794], [517, 847], [340, 850]], [[342, 929], [517, 931], [516, 981], [341, 979]], [[547, 930], [641, 930], [641, 983], [547, 983]], [[671, 932], [842, 932], [842, 981], [671, 981]], [[3