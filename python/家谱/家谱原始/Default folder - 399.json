0, 2203], [1648, 2206], [1648, 2253], [280, 2250]], [[280, 2262], [1161, 2266], [1160, 2313], [280, 2309]]], "rec_boxes": [[278, 241, 1648, 294], [280, 304, 1647, 354], [279, 365, 1642, 415], [277, 426, 1646, 475], [278, 487, 1642, 536], [283, 553, 987, 593], [356, 610, 512, 653], [358, 674, 1643, 714], [99, 686, 192, 879], [281, 732, 1644, 775], [280, 791, 1645, 837], [281, 854, 1643, 899], [280, 914, 1644, 961], [106, 975, 186, 1360], [281, 977, 1644, 1022], [279, 1037, 1645, 1084], [279, 1098, 1645, 1146], [280, 1160, 1644, 1209], [279, 1221, 1647, 1267], [277, 1281, 1646, 1329], [276, 1340, 1647, 1392], [277, 1402, 1643, 1448], [278, 1464, 1639, 1511], [279, 1528, 1414, 1571], [358, 1590, 1639, 1632], [279, 1650, 1644, 1694], [278, 1709, 1645, 1758], [278, 1773, 1643, 1819], [278, 1835, 1642, 1884], [278, 1898, 1643, 1945], [278, 1959, 1643, 2008], [114, 1972, 169, 2093], [278, 2020, 989, 2067], [358, 2083, 1646, 2130], [281, 2144, 1647, 2191], [280, 2203, 1648, 2253], [280, 2262, 1161, 2313]]}}, "markdown": {"text": "## 渑池杜氏宗谱\n\n三九九\n\n诽谤木逐渐演变成今天的华表，成为建筑的装饰和权力的象征，失去了最初纳谏的美德含义。追溯华表的由来，人们感叹的是早在4500年前，上古尧帝就有如此仁贤开明的民主作风。他治天下五十年，微服访于民间，有一位老人含着食，鼓着腹，敲着土地唱道：“日出而作，日入而息，凿井而饮，耕田而食，帝力于我何有哉。”这首古诗称作《击壤歌》。这首《击壤歌》是我国流传最早的歌谣，它歌颂的是帝尧时期太平盛世的安逸生活。\n\n\n\n## 唐尧迁都\n\n西徙太原。大约在距今四千五百多年的古代，唐尧的部族活动于今河北省唐县至望都一带的滹沱河流域。《后汉书·郡国志》唐县条引注：“《帝王世纪》曰：尧封唐，尧山在北，唐水西入河，南有望都。”《水经注》《元和郡县图志》《舆地广记》及《太平寰宇记》等著名的古代地理志书，都持此说。徐旭生《中国古代史的传说时代》：“陶唐氏旧城应该是今河北唐县、望都一代。”邹衡在《夏商周考古学论文集·论先周文化》与周长富《浅谈唐尧氏》都指出：从年代和分布范围来讲，河北龙山文化相当于唐尧氏古族。何光岳先生在其名著《炎黄源流史》中认为，唐尧为避免东夷部族的侵扰，遂率部西徙，“从唐县、望都一带出发南下行唐，沿滹沱河过井陉，途经太原，再进人平阳。”（《试谈唐尧氏》）。上述论述和地下出土文物的相互佐证，证实了唐尧部族由河北唐县、望都一带西徙太原，定居太原可能性的真实存在。另一说是，《尚书·尧曲》说：“尧之时洪水为患为甚”；《寰宇通志》：“尧时上游之水无所痒，壅而四出”；《晋乘搜略》说：“尧时黄水为患，震及帝都。”或许正是因为常常受到唐河、滹沱河水患浸害，所以唐尧才携带部族来到了汾河中游的河谷地带，今太原盆地。总之，在汾河中游平原的大地上唐尧部族和太原先民共创太原的龙山文化。\n\n初都太原。司马迁《史记》的《五帝本纪·正义》中的《宗国都城记》云：“唐国，帝尧之裔子所封。”班固《汉书·地理志》载：“晋阳本唐国，尧始都于此。”《都城记》也说：“晋阳城北二里有唐城，尧所筑。”唐城是帝尧所筑，唐城地处太原晋阳一带。所以太原有了“唐”和“唐国”的古名。追溯“唐”的古意，《说文解字》解释为“唐，大言也。”《白虎通·号》解释为“唐，荡荡也，道德至大之貌也。”正是因尧得唐号，称为唐尧，所以才使属地有了唐的名称。古称“唐”的地名至少有三处：河北之“唐”、太原之“唐”、山西晋南之“唐”，都是因唐尧多次迁徙曾经定居那里而得名。\n\n\n\n再迁平阳。尧和尧的部族，留下了太原的唐文化和古唐城，又沿着汾河南流的方向继续迁徙于临汾盆地—平阳。东汉人郑玄《诗谱》中说：“尧始居晋阳，后迁河东。”清著名汉书家阎若琚《尚书疏证》中说：“尧为天子实先都晋阳，后迁平阳府。”于是，又有了“尧都平阳”之说。\n\n", "isStart": false, "isEnd": true, "images": {}}, "outputImages": {"layout_det_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//1c75dc46-13d9-4fd1-9de7-209c83c43e9d/layout_det_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A36%3A22Z%2F-1%2F%2Fb591a1a7f86e973f3d70ae1c07f8231257b1f5f2c95d9bb2d149a5698a6659df", "region_det_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//1c75dc46-13d9-4fd1-9de7-209c83c43e9d/region_det_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A36%3A23Z%2F-1%2F%2F3c01a317abe3e3803933ce561dbb9db38acb29eb73c06c68606a98846928085b", "overall_ocr_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//1c75dc46-13d9-4fd1-9de7-209c83c43e9d/overall_ocr_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A36%3A23Z%2F-1%2F%2F78865ded7fba9a163d90459b8f7628684ebfdeda1478e42761b5a3432fa1869e", "layout_order_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//1c75dc46-13d9-4fd1-9de7-209c83c43e9d/layout_order_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A36%3A23Z%2F-1%2F%2Faf7fb1623e9e84965ad6dd4e03f8c671ed725215fdfe9c71acf812bfca8c4200"}, "inputImage": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//1c75dc46-13d9-4fd1-9de7-209c83c43e9d/input_img_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A36%3A22Z%2F-1%2F%2F0cbd0c39a04ece7f5a83e4c968264d93447c64be02af5cdae45dc49e1e8a51d1"}], "dataInfo": {"width": 1825, "height": 2600, "type": "image"}, "ocrResults": [{"prunedResult": {"model_settings": {"use_doc_prepr