9], [1731, 383], [295, 384]], [[295, 402], [1730, 402], [1730, 445], [295, 445]], [[297, 464], [1408, 464], [1408, 507], [297, 507]], [[379, 528], [1367, 528], [1367, 568], [379, 568]], [[299, 589], [759, 591], [759, 632], [299, 630]], [[379, 651], [1730, 648], [1730, 692], [379, 695]], [[121, 671], [218, 671], [218, 868], [121, 868]], [[297, 709], [1731, 710], [1731, 757], [297, 756]], [[298, 774], [1730, 774], [1730, 817], [298, 817]], [[298, 833], [1728, 835], [1728, 879], [298, 877]], [[299, 894], [1727, 897], [1727, 941], [299, 938]], [[131, 962], [211, 962], [211, 1347], [131, 1347]], [[298, 956], [1727, 960], [1727, 1004], [298, 1000]], [[298, 1018], [1727, 1023], [1727, 1067], [298, 1062]], [[299, 1079], [1726, 1084], [1726, 1128], [299, 1123]], [[299, 1140], [1725, 1145], [1725, 1189], [299, 1184]], [[299, 1201], [1726, 1207], [1726, 1251], [299, 1245]], [[297, 1260], [1727, 1267], [1727, 1313], [297, 1306]], [[294, 1317], [446, 1317], [446, 1371], [294, 1371]], [[1037, 1388], [1660, 1392], [1659, 1436], [1037, 1432]], [[1066, 1450], [1631, 1454], [1630, 1498], [1066, 1494]], [[814, 1903], [1120, 1903], [1120, 1951], [814, 1951]], [[827, 1956], [1137, 1956], [1137, 2018], [827, 2018]], [[142, 1988], [196, 1988], [196, 2039], [142, 2039]]], "rec_boxes": [[297, 217, 1730, 265], [297, 279, 1729, 323], [295, 339, 1731, 384], [295, 402, 1730, 445], [297, 464, 1408, 507], [379, 528, 1367, 568], [299, 589, 759, 632], [379, 648, 1730, 695], [121, 671, 218, 868], [297, 709, 1731, 757], [298, 774, 1730, 817], [298, 833, 1728, 879], [299, 894, 1727, 941], [131, 962, 211, 1347], [298, 956, 1727, 1004], [298, 1018, 1727, 1067], [299, 1079, 1726, 1128], [299, 1140, 1725, 1189], [299, 1201, 1726, 1251], [297, 1260, 1727, 1313], [294, 1317, 446, 1371], [1037, 1388, 1660, 1436], [1066, 1450, 1631, 1498], [814, 1903, 1120, 1951], [827, 1956, 1137, 2018], [142, 1988, 196, 2039]]}}, "markdown": {"text": "八世祖、王都一支六世祖，名不可考，无从以详，阙待后得其详者补。族侄从新，接余信后，即将其父留给始祖墓碣原文恭录，由卢氏专程送回，以供付梓，是为不足中美。然此续修之事，事至苦而情之艰也，故将其一心以赴而献身奔成者、义行酬本而捐资以助者、劳苦不辞而征集续资者、寒暑不避心劳不厌而笔录正编者、多方求益以达续修目的而鼎力付梓者，一并名列于后，以志不忘。是为序。\n\n十五世杜俊英于戊辰春二月既望，十六世杜金铎付梓贴附文标续修主办者名列于后：\n\n## 渑池杜氏宗谱\n\n从来智者尽谋、勇者效忠、仁者行义。族弟俊良、族季平泉，禀赋聪颖，敏而勤学、稳重学固，身润德厚，博闻多识，道积厥躬，从教数十载，诲不倦，育才济济，桃李遍地，器闻成才者颇不乏人。为族名流，一方良师，邑东望人，足称“僻校育英才，陋室培异器”。族之明达丙德、云芳、光荣、义荣、二丙、钟庭、东振、成寅、镇藩、丙文、文和、勤午、登楼、敏曾、五岳、建修、成金、清峰等，俱热心公益，笃于族谊，率先肇修吾杜氏宗谱，主办一切续修事宜。而又遣人四往，征取续资，寒暑不避，风雨不阻，劳而不怨，烦而不厌，栉风沐雨，胝足千里。配合俊良、平泉合力续修。一心一德，日夜操劳，千辛万苦，而竟其事。群贤此举，显先启后，仁以安存没之心。其德川流，淳化遗后人以规。为全族而奔走，为全族而努力，对于吾族俱不无一时之功。其功可歌，其德可颂。族之期望，俱闻而嘉之，众意而敬慕。故谆谆恳恳，再三之嘱，谕以文标，余受合族期望之嘱，匆付数语，稍达群季之功于一二，不没报本追远之热诚、敦伦厚俗之义行。\n\n\n\n十五世杜俊英撰，十七世杜好信正误公元一九八八年戊辰春二月下旬", "isStart": true, "isEnd": true, "images": {}}, "outputImages": {"layout_det_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//e7b78d71-16a7-4f3d-948a-43c878774d38/layout_det_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A45%3A09Z%2F-1%2F%2Fb3b581e166102fd55154734151f9f169c327f21a9901d0f4ab7a057ecbbc34c0", "region_det_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//e7b78d71-16a7-4f3d-948a-43c878774d38/region_det_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A45%3A10Z%2F-1%2F%2F1e1f569973b4a3430da0592d822175f7c7b3b46bc2575ad5ce7b24e54f50b1d9", "overall_ocr_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//e7b78d71-16a7-4f3d-948a-43c878774d38/overall_ocr_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A45%3A10Z%2F-1%2F%2Fc2ef4718faaa1985551f0cfd00d2c305636d756567ac3fa272715320a0a462f8", "layout_order_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//e7b78d71-16a7-4f3d-948a-43c878774d38/layout_order_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A45%3A10Z%2F-1%2F%2F464a0deca6cbe89d9cbee5737a6a5289b4d9664b4a3123a196c082a625e01d37"}, "inputImage": "https://p