1109], [1747, 1116], [1747, 1165], [312, 1158]], [[309, 1170], [460, 1170], [460, 1224], [309, 1224]], [[147, 1961], [204, 1961], [204, 2074], [147, 2074]], [[1345, 2039], [1677, 1823], [1910, 2181], [1578, 2397]]], "rec_boxes": [[895, 227, 1174, 298], [396, 357, 1757, 403], [312, 419, 1756, 467], [310, 482, 1753, 529], [312, 544, 1753, 590], [311, 605, 1668, 653], [130, 676, 228, 876], [312, 672, 1232, 715], [393, 731, 1719, 779], [309, 795, 1202, 845], [768, 854, 1201, 912], [1104, 918, 1199, 974], [139, 968, 223, 1359], [944, 986, 1197, 1035], [394, 1046, 1746, 1100], [312, 1109, 1747, 1165], [309, 1170, 460, 1224], [147, 1961, 204, 2074], [1345, 1823, 1910, 2397]]}}, "markdown": {"text": "## 东张村\n\n东张村位于渑池县仁村乡东南四公里处，是渑池县仁村乡的一个建制村。原称张村，以同县的张村镇也有一同名之村而称。下辖东张村、西张村、寨南等3个自然村。东张村背靠小虎坡，面对青龙山，东张村古来是形胜之地，南边原有奎星楼、龙王庙、奶奶庙各一座，当地流传有小虎坡的传说故事。2007年由中铝公司投资修建一条宽30多米的人工河道，河道两旁十米多宽的沿海大道全部铺成柏油路面。杜氏家族从仁村乡大水沟村迁移至此，其迁入世系为：\n\n流芳公——忠——果—真银——三元—乘龙——兰——彬——允法—朝选——林邦——文秀——荣升——林清—作栋\n\n\n\n林富—作新\n\n原迁入时仅十几口人，现已发展到一百多口人，占全村人口的六分之一，高中以上学历占杜氏人口的30%，其中北京大学学历一人，正县级干部一人，正科级干部一人。\n\n\n\n一八七", "isStart": false, "isEnd": true, "images": {}}, "outputImages": {"layout_det_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//bef4635d-e6b0-40b3-a1b3-23520d095832/layout_det_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A10%3A55Z%2F-1%2F%2F522a0539fabc9f1f91f9af001b8d40c01bc0ae8c83422b43759d447dd67ac554", "region_det_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//bef4635d-e6b0-40b3-a1b3-23520d095832/region_det_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw%2F2026-06-19T02%3A10%3A55Z%2F-1%2F%2Ff5e9a7a6ef0539d512b0f616fc59f1321135ef64798a61177b0767d28566216c", "overall_ocr_res": "https://pplines-online.bj.bcebos.com/deploy/official/paddleocr/structure-v3-online//bef4635d-e6b0-40b3-a1b3-23520d095832/overall_ocr_res_0.jpg?authorization=bce-auth-v1%2FALTAKDN8mY5KlNI7zaRpLmOqrw